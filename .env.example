CBNUAI_API_KEY=your_cbnuai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
MFDS_API_KEY=your_mfds_api_key_here

# 건기식 인식용 AI DB (supplement_info, supplement_product_markers)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=click_db
MYSQL_USER=click_user
MYSQL_PASSWORD=clickpassword
MYSQL_HOST=localhost
MYSQL_PORT=3306

# 처방전 인식용 약 DB (pill_products, canonical_drug_entities)
# 미설정 시 위 MYSQL_* 값을 사용하며 기본 포트는 3307
PILL_MYSQL_HOST=localhost
PILL_MYSQL_PORT=3307
PILL_MYSQL_DATABASE=click_backend_db
PILL_MYSQL_USER=click_user
PILL_MYSQL_PASSWORD=clickbackend_password
